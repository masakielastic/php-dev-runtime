{
    "name": "masakielastic/php-dev-runtime",
    "description": "Minimal ReactPHP-based HTTP runtime for development and project-local applications.",
    "type": "library",
    "license": "MIT",
    "require": {
        "amphp/hpack": "^3.2",
        "php": "^8.2",
        "nyholm/psr7": "^1.8",
        "psr/http-message": "^1.1 || ^2.0",
        "react/event-loop": "^1.5",
        "react/http": "^1.11",
        "react/promise": "^3.2",
        "react/socket": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "PhpDevRuntime\\": "src/"
        }
    },
    "bin": [
        "bin/dev-server"
    ]
}
