#!/usr/bin/env php
<?php

declare(strict_types=1);

use PhpDevRuntime\Console\ServeCommand;

$autoload = __DIR__ . '/../vendor/autoload.php';

if (!is_file($autoload)) {
    fwrite(STDERR, "vendor/autoload.php was not found. Run composer install first.\n");
    exit(1);
}

require $autoload;

exit((new ServeCommand())->run($argv));
